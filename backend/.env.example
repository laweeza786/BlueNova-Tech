# ─────────────────────────────────────────────────────────────────────────────
# BlueNova ERP — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to git.
# ─────────────────────────────────────────────────────────────────────────────

# Django secret key — generate a fresh one with:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Set to False in production (Railway)
DEBUG=False

# Comma-separated list of allowed hosts
# On Railway, set this to your Railway public domain e.g.: myapp.up.railway.app
ALLOWED_HOSTS=localhost,127.0.0.1

# ─────────────────────────────────────────────────────────────────────────────
# CSRF — Required when DEBUG=False (add your Railway domain here)
# ─────────────────────────────────────────────────────────────────────────────
# CSRF_TRUSTED_ORIGINS=https://myapp.up.railway.app

# ─────────────────────────────────────────────────────────────────────────────
# Database — Railway injects DATABASE_URL automatically for PostgreSQL add-ons
# Leave blank for local SQLite development (default)
# ─────────────────────────────────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─────────────────────────────────────────────────────────────────────────────
# Cloudinary — Required for persistent media file storage on Railway
# Without this, uploaded files (profile pics, resumes) are LOST on every deploy.
#
# Get your URL from: https://cloudinary.com/console
# Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# ─────────────────────────────────────────────────────────────────────────────
# CLOUDINARY_URL=cloudinary://123456789012345:abcdefghijklmnopqrstuvwxyz@your-cloud-name
