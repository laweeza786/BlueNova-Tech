# ─────────────────────────────────────────────────────────────────────────────
# BlueNova ERP — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to git.
# ─────────────────────────────────────────────────────────────────────────────

# Django secret key — generate a fresh one with:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Set to False in production
DEBUG=True

# Comma-separated list of allowed hosts, e.g. localhost,127.0.0.1,yourdomain.com
ALLOWED_HOSTS=*

# ─────────────────────────────────────────────────────────────────────────────
# Database (SQLite is default; switch to PostgreSQL for production)
# ─────────────────────────────────────────────────────────────────────────────
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=bluenova_erp
# DB_USER=postgres
# DB_PASSWORD=yourpassword
# DB_HOST=localhost
# DB_PORT=5432
